{
  "$schema": "https://opencode.ai/config.json",
  "tool_output": {
    "max_lines": 800,
    "max_bytes": 24000
  },
  "agent": {
    "rustynet-report-review": {
      "model": "deepseek-direct/deepseek-v4-flash",
      "mode": "primary",
      "description": "Read-only Rustynet live-lab failure report reviewer.",
      "steps": 18,
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "bash": false,
        "edit": false,
        "task": false,
        "todowrite": false,
        "webfetch": false,
        "websearch": false,
        "lsp": false,
        "skill": false
      },
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "task": "deny",
        "todowrite": "deny",
        "question": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    },
    "rustynet-edit-full": {
      "mode": "primary",
      "description": "Rustynet delegated-edit agent, FULL autonomy. Driven by the ai_edit_run MCP tool inside an isolated git worktree; never run against the shared working tree. Edits without per-change approval, self-verifies with gates, surfaces a diff for human review+merge. Model is passed per-call, not pinned here.",
      "steps": 250,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "allow",
        "bash": "allow",
        "todowrite": "allow",
        "task": "deny",
        "question": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    },
    "rustynet-edit-restricted": {
      "mode": "primary",
      "description": "Rustynet delegated-edit agent, RESTRICTED. Same as rustynet-edit-full except every file mutation pauses for explicit approval from the driving agent (edit=ask, surfaced via ai_edit_result and answered with ai_edit_approve/ai_edit_deny). bash stays allow so investigation/gates don't need per-command sign-off — edit is the action that actually mutates state. Model is passed per-call, not pinned here.",
      "steps": 120,
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "ask",
        "bash": "allow",
        "todowrite": "allow",
        "task": "deny",
        "question": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    },
    "rustynet-loop-main": {
      "model": "deepseek/deepseek-v4-pro",
      "variant": "max",
      "mode": "primary",
      "description": "Rustynet live-lab loop patch/gate/relaunch agent.",
      "steps": 250,
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "edit": true,
        "bash": true,
        "todowrite": true,
        "task": false,
        "webfetch": false,
        "websearch": false,
        "lsp": false,
        "skill": false
      },
      "permission": {
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "edit": "allow",
        "todowrite": "allow",
        "bash": "allow",
        "task": "deny",
        "question": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "deny",
        "skill": "deny",
        "external_directory": "deny"
      }
    }
  },
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek API",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro"
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        }
      }
    }
  },
  "mcp": {
    "rustynet-repo-context": {
      "type": "local",
      "command": ["/Users/iwan/Desktop/Rustynet/bin/rustynet-mcp-repo-context"],
      "enabled": true
    },
    "rustynet-gate-runner": {
      "type": "local",
      "command": ["/Users/iwan/Desktop/Rustynet/bin/rustynet-mcp-gate-runner"],
      "enabled": true
    },
    "rustynet-lab-state": {
      "type": "local",
      "command": ["/Users/iwan/Desktop/Rustynet/bin/rustynet-mcp-lab-state"],
      "enabled": true
    },
    "rustynet-ai-agent": {
      "type": "local",
      "command": ["/Users/iwan/Desktop/Rustynet/bin/rustynet-mcp-ai-agent"],
      "enabled": true
    }
  }
}
