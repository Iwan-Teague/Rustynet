/target/
/fuzz/artifacts/
/fuzz/corpus/
/fuzz/coverage/
/fuzz/target/
/fuzz/Cargo.lock
/.ci-home/
/.cargo-home/
/.cargo-audit-db/
/.cargo-audit-db
/.cargo-audit-db..lock
/.cargo-audit-db*

# MCP server build output (binaries built by scripts/mcp/install.sh into ./bin).
# Build from source; do not commit the compiled servers.
/bin/

# Editor-local config (absolute machine paths; wire up via scripts/mcp/install.sh).
/.zed/

# Local desktop noise
.DS_Store
__pycache__/

# Generated artifacts are local-only by default.
# Existing tracked artifact files remain tracked until explicitly removed from the index.
/artifacts/**
!/artifacts/**/.gitkeep
# Live-lab report directories written by `ops vm-lab-setup-live-lab` and
# `ops vm-lab-run-live-lab` land here (state/live-lab-<UTC>/). They are
# local-only evidence — the run wrapper refuses to generate the
# commit-bound fresh-install OS matrix report from a dirty tree, so
# leaving these dirs untracked would otherwise hard-fail every live lab
# run with `cannot generate commit-bound … report from a dirty working
# tree`.
/state/**
/profiles/live_lab/*.env
/profiles/live_lab/generated_vm_lab_*_known_hosts
!/profiles/live_lab/default_four_node.env
!/profiles/live_lab/default_five_node.env
/third_party/boringtun/.cargo-ok
/third_party/boringtun/.cargo_vcs_info.json
/third_party/boringtun/Cargo.toml.orig
.aider*
