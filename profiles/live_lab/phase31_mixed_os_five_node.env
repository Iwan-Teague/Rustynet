# Phase 31 mixed-OS full live-lab profile.
#
# Linux core: exit/client/relay. Desktop sidecars: macOS aux + Windows extra.
# This profile is code-side validation input only until operator runs live labs.
EXIT_TARGET="debian@192.168.65.3"
EXIT_UTM_NAME="debian-headless-1"
EXIT_PLATFORM="linux"
EXIT_REMOTE_SHELL="posix"
EXIT_GUEST_EXEC_MODE="linux_bash"
EXIT_SERVICE_MANAGER="systemd"
EXIT_RUSTYNET_SRC_DIR="/home/debian/Rustynet"

CLIENT_TARGET="debian@192.168.65.4"
CLIENT_UTM_NAME="debian-headless-2"
