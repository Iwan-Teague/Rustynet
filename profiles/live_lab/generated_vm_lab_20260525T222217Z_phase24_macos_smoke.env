# Phase 24 macOS bring-up smoke profile (no Windows; 5 Debian + 1 macOS = 6 nodes).
#
# Used for Phase 24 follow-up: validates macOS daemon reaches ExitActive in a
# 6-node membership with WG handshakes to Debian peers. live_mixed_topology
# stage skips because EXTRA_PLATFORM is linux not windows; that part of the
# Phase 24 acceptance is separately blocked on Windows VM paging exhaustion
# (see artifacts/live_lab/phase25-windows-bootstrap/).
#
# 2026-05-27 bridged-mode rework: every VM is now in UTM "Bridged" network
# mode, on the host's home LAN (192.168.12.0/22). Previously the macOS aux
# lived on UTM Apple-Virtualization shared net (bridge100/192.168.64.0/24)
# and the Debian VMs on QEMU shared net (bridge101/192.168.65.0/24); those
# two vmnets did not route to each other, so cross-OS WireGuard handshakes
# could not complete. Single broadcast domain is the simplest reliable fix.
EXIT_TARGET="debian@192.168.0.200"
CLIENT_TARGET="debian@192.168.0.201"
ENTRY_TARGET="debian@192.168.0.202"
AUX_TARGET="mac@192.168.0.210"
EXTRA_TARGET="debian@192.168.0.203"
FIFTH_CLIENT_TARGET="debian@192.168.0.204"
EXIT_UTM_NAME="debian-headless-1"
CLIENT_UTM_NAME="debian-headless-2"
ENTRY_UTM_NAME="debian-headless-3"
AUX_UTM_NAME="macOS"
EXTRA_UTM_NAME="debian-headless-4"
FIFTH_CLIENT_UTM_NAME="debian-headless-5"
EXIT_PLATFORM="linux"
CLIENT_PLATFORM="linux"
ENTRY_PLATFORM="linux"
AUX_PLATFORM="macos"
EXTRA_PLATFORM="linux"
FIFTH_CLIENT_PLATFORM="linux"
EXIT_REMOTE_SHELL="posix"
CLIENT_REMOTE_SHELL="posix"
ENTRY_REMOTE_SHELL="posix"
AUX_REMOTE_SHELL="posix"
EXTRA_REMOTE_SHELL="posix"
FIFTH_CLIENT_REMOTE_SHELL="posix"
EXIT_GUEST_EXEC_MODE="linux_bash"
CLIENT_GUEST_EXEC_MODE="linux_bash"
ENTRY_GUEST_EXEC_MODE="linux_bash"
AUX_GUEST_EXEC_MODE="macos_posix"
EXTRA_GUEST_EXEC_MODE="linux_bash"
FIFTH_CLIENT_GUEST_EXEC_MODE="linux_bash"
EXIT_SERVICE_MANAGER="systemd"
CLIENT_SERVICE_MANAGER="systemd"
ENTRY_SERVICE_MANAGER="systemd"
AUX_SERVICE_MANAGER="launchd"
EXTRA_SERVICE_MANAGER="systemd"
FIFTH_CLIENT_SERVICE_MANAGER="systemd"
SSH_IDENTITY_FILE="/Users/iwan/.ssh/rustynet_lab_ed25519"
SSH_KNOWN_HOSTS_FILE="/Users/iwan/Desktop/Rustynet/profiles/live_lab/20260525_phase24_mixed_known_hosts"
SSH_ALLOW_CIDRS="192.168.0.0/24"
RUSTYNET_BACKEND="linux-wireguard-userspace-shared"
SOURCE_MODE="working-tree"
REPORT_DIR="artifacts/live_lab/phase24-macos-smoke/20260525T222217Z/orchestrator"
